# AR Furniture Preview - Environment Configuration
# Copy this file to .env.local and fill in values as needed

# Application Environment
NODE_ENV=production

# Next.js Configuration
# NEXT_PUBLIC_APP_URL is used for absolute URLs in metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics (optional)
# Leave empty to disable analytics
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=false

# API Configuration (if needed for future enhancements)
# NEXT_PUBLIC_API_URL=https://api.example.com
